record(ao, "$(P=RPTEST:)PVVALUE11") {
    field(DESC, "Value 1 column 1")
}

record(ao, "$(P=RPTEST:)PVVALUE21") {
    field(DESC, "Value 2 column 1")
}




record(ao, "$(P=RPTEST:)PVVALUE1") {
    field(DESC, "Value 1 column 1")
}


record(compress, "$(P=RPTEST:)PVTESTCOMP") {
    field(DESC, "Record to add values to 1st column")
    field(INP, "$(P=RPTEST:)PVVALUE1")
    field(ALG, "Circular Buffer")
    field(NSAM, "10")
    field(BALG, "FIFO Buffer")
    field(FLNK, "$(P=RPTEST:)PVRESULT")
}


record(waveform, "$(P=RPTEST:)PVRESULT"){
    field(DESC, "1st column")
    field(INP, "$(P=RPTEST:)PVTESTCOMP")
    field(NELM, "10")
    field(FTVL, "DOUBLE")
    info(Q:group, {
        "$(P=RPTEST:)MyTable":{
            "value.VALUE1":{+type:"plain", +channel:"VAL"}
        }
    })
}

# VALUE 2 - Column 2

record(ao, "$(P=RPTEST:)PVVALUE12") {
    field(DESC, "Value 1 column 2")
}

record(ao, "$(P=RPTEST:)PVVALUE22") {
    field(DESC, "Value 2 column 2")
}

record(ao, "$(P=RPTEST:)PVVALUE2") {
    field(DESC, "Value 2")
}

record(compress, "$(P=RPTEST:)PVTESTCOMP2") {
    field(DESC, "Record to add values to 2nd column")
    field(INP, "$(P=RPTEST:)PVVALUE2")
    field(ALG, "Circular Buffer")
    field(NSAM, "10")
    field(BALG, "FIFO Buffer")
    field(FLNK, "$(P=RPTEST:)PVRESULT2")
}


record(waveform, "$(P=RPTEST:)PVRESULT2"){
    field(DESC, "2nd column")
    field(INP, "$(P=RPTEST:)PVTESTCOMP2")
    field(NELM, "10")
    field(FTVL, "DOUBLE")
    info(Q:group, {
        "$(P=RPTEST:)MyTable":{
            "value.VALUE2":{+type:"plain", +channel:"VAL"}
        }
    })
}

# Field with strings

record(waveform, "$(P=RPTEST:)PVRESULT3"){
    field(NELM, "10")
    field(FTVL, "STRING")
    info(Q:group, {
        "$(P=RPTEST:)MyTable":{
            "value.VALUE3":{+type:"plain", +channel:"VAL"}
        }
    })
}

# Table


record(aai, "$(P=RPTEST:)Titles") {
    field(FTVL, "STRING")
    field(NELM, "3")
    field(PINI,"YES")
    field(INP , {const:["Values", "Other Values", "More values"]})
    info(Q:group, {
        "$(P=RPTEST:)MyTable":{
            +id:"epics:nt/NTTable:1.0",
            "labels":{+type:"plain", +channel:"VAL"}
        }
    })
}

# Add point 1 (to both columns, 1 and 2)
record(bo, "$(P=RPTEST:)Add1") {
    field(FLNK, "$(P=RPTEST:)#Add1Seq")
}

record(seq, "$(P=RPTEST:)#Add1Seq") {
    field(DOL0, "$(P=RPTEST:)PVVALUE11")
    field(LNK0, "$(P=RPTEST:)PVVALUE1")
    field(DOL1, "1")
    field(LNK1, "$(P=RPTEST:)PVTESTCOMP.PROC")


    field(DOL2, "$(P=RPTEST:)PVVALUE12")
    field(LNK2, "$(P=RPTEST:)PVVALUE2")
    field(DOL3, "1")
    field(LNK3, "$(P=RPTEST:)PVTESTCOMP2.PROC")
}


# Add point 2
record(bo, "$(P=RPTEST:)Add2") {
    field(FLNK, "$(P=RPTEST:)#Add2Seq")
}

record(seq, "$(P=RPTEST:)#Add2Seq") {
    field(DOL0, "$(P=RPTEST:)PVVALUE21")
    field(LNK0, "$(P=RPTEST:)PVVALUE1")
    field(DOL1, "1")
    field(LNK1, "$(P=RPTEST:)PVTESTCOMP.PROC")

    field(DOL2, "$(P=RPTEST:)PVVALUE22")
    field(LNK2, "$(P=RPTEST:)PVVALUE2")
    field(DOL3, "1")
    field(LNK3, "$(P=RPTEST:)PVTESTCOMP2.PROC")
}
